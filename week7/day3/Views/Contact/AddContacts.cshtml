<h2>Add Contact</h2>

<form method="post" asp-controller="Contact" asp-action="AddContacts">

    <input type="number" name="ContactId" placeholder="ID" required />
    <br/><br/>
    <input type="text" name="FirstName" placeholder="First Name" required />
    <br /><br/>
    <input type="text" name="LastName" placeholder="Last Name" required />
    <br /><br/>
    <input type="text" name="CompanyName" placeholder="Company" required />
    <br /><br/>
    <input type="email" name="EmailId" placeholder="Email" required />
    <br /><br/>
    <input type="number" name="MobileNo" placeholder="Mobile" required />
    <br /><br/>
    <input type="text" name="Designation" placeholder="Designation" required />
    <br /><br/>

    <button type="submit" >Save</button>
</form>
