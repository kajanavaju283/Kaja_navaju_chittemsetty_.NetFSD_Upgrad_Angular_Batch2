@model DataAccessLayer.Models.ContactInfo

<h2>Edit Contact</h2>

<form method="post" asp-action="EditContact">

    <input type="hidden" asp-for="ContactId" />

    First Name:
    <input asp-for="FirstName" /><br />

    Last Name:
    <input asp-for="LastName" /><br />

    Email:
    <input asp-for="EmailId" /><br />

    Mobile:
    <input asp-for="MobileNo" /><br />

    Designation:
    <input asp-for="Designation" /><br />

    Company:
    <select asp-for="CompanyId">
        @foreach (var c in ViewBag.Companies)
        {
            <option value="@c.CompanyId"
                    selected="@(c.CompanyId == Model.CompanyId)">
                @c.CompanyName
            </option>
        }
    </select><br />

    Department:
    <select asp-for="DepartmentId">
        @foreach (var d in ViewBag.Departments)
        {
            <option value="@d.DepartmentId"
                    selected="@(d.DepartmentId == Model.DepartmentId)">
                @d.DepartmentName
            </option>
        }
    </select><br />

    <button type="submit">Update</button>

</form>
